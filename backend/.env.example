# Database (Supabase Postgres URI)
DATABASE_URL=postgres://postgres.xxxxx:password@aws-0-regionpool.supabase.co:5432/postgres

# Optional — Supabase JS client (for realtime, etc.)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

PORT=3001
SPHERE_MNEMONIC=
SPHERE_NAMETAG=@otcmarket
NETWORK=testnet

# Admin dashboard (set a strong random value)
ADMIN_KEY=change-me-to-something-secret
